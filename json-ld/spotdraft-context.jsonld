    "address": "schema:address",
    "externalId": "spotdraft:externalId",
    "compositeId": "spotdraft:compositeId",
    "contractId": "spotdraft:contractId",
    "templateId": "spotdraft:templateId",
    "counterpartyId": "spotdraft:counterpartyId",
